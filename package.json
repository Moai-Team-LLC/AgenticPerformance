{
  "name": "agent-performance-layer",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "scripts": {
    "tsc": "tsc --noEmit -p packages/core/tsconfig.json && tsc --noEmit -p apps/ingest/tsconfig.json && tsc --noEmit -p apps/worker/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "dotenvx run -f .env.local -- drizzle-kit generate",
    "db:migrate-local": "dotenvx run -f .env.local -- drizzle-kit migrate"
  },
  "dependencies": {
    "drizzle-kit": "0.31.10",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@dotenvx/dotenvx": "^1.67.0",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "bun@1.3.11"
}
