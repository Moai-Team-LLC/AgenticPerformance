# APL environment (copy to .env.local for local dev)

# Postgres with the `vector`, `vectorscale`, and `timescaledb` extensions —
# `docker compose up -d` provides one on host port 5439 (the migration creates
# the extensions itself, so no init scripts are needed).
DATABASE_URL=postgresql://postgres:postgres@localhost:5439/postgres

# Chat provider for the LLM tails (judge runner, taxonomy, L2 proposer).
# Any OpenAI-compatible endpoint. Optional until you enable those features.
APL_CHAT_BASE_URL=https://api.openai.com/v1
APL_CHAT_API_KEY=

# Ingest server port (apps/ingest).
PORT=4319

# Set to require `Authorization: Bearer <token>` on POST /v1/traces
# (health stays open). Empty = open ingest, dev only.
APL_INGEST_TOKEN=

# Max ingest request-body size in bytes (default 5000000 = 5 MB).
APL_MAX_BODY_BYTES=5000000
